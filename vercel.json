{
  "version": 2,
  "builds": [
    {
      "src": "apps/site/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/apps/site/$1" }
  ],
  "env": {
    "PUBLIC_SITE_URL": "https://asc3nd.org",
    "NEXT_PUBLIC_DONATION_URL": "https://donate.asc3nd.org"
  }
}
